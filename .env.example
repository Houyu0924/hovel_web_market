# OpenAI API key. Never commit the real value.
OPENAI_API_KEY=

# AI generation is opt-in. Default is deterministic local output.
HOVEL_AI_ENABLED=false
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=2

# true: continue with deterministic draft when API fails
# false: stop the workflow on API failure
HOVEL_AI_FALLBACK_ENABLED=true
